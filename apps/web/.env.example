# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_SECONDS=43200

# Database — SQLite (local dev) or Turso (production)
# Local: sqlite:///data/db.sqlite (relative to app root, stored in data/ volume)
# Turso: libsql+https://[your-db-url].turso.io?authToken=[your-token]
DATABASE_URL=sqlite:///data/db.sqlite
# TURSO_AUTH_TOKEN=your-turso-auth-token (only needed for libsql+turso:// URLs)

# Google Sheets
GOOGLE_CREDENTIALS_FILE=credentials/service-account.json
SPREADSHEET_ID=your-google-sheet-id-here
SHEETS_CACHE_TTL=30
SHEETS_VALIDATE_HEADERS_ON_STARTUP=false
SHEETS_STARTUP_MAX_RETRIES=5
SHEETS_STARTUP_RETRY_BASE_SECONDS=1.5

# Discord OAuth (staff dashboard)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://127.0.0.1:5001/auth/callback
ALLOWED_DISCORD_IDS=123456789012345678
# Moderator IDs — subset of ALLOWED_DISCORD_IDS with config/admin access.
# Leave empty to give all staff full Moderator access (good for small teams).
MODERATOR_DISCORD_IDS=

# Shared bearer token for bot API routes under /api/*
WEB_APP_API_TOKEN=change-me-bot-api-token
# Optional scoped tokens (if set, scope enforcement applies)
# WEB_APP_API_READ_TOKEN=change-me-read-token
# WEB_APP_API_WRITE_TOKEN=change-me-write-token

# Optional replay protection for bot write routes (/api/claims, /api/spends)
# BOT_API_REPLAY_PROTECTION_ENABLED=true
# BOT_API_REPLAY_WINDOW_SECONDS=300
# BOT_API_NONCE_TTL_SECONDS=600
# BOT_API_NONCE_CACHE_SIZE=10000

# Optional auto-create next play period (bot-triggered via /api/periods/auto-create)
AUTO_CREATE_PERIODS_ENABLED=false
AUTO_CREATE_PERIODS_OPEN_LEAD_DAYS=1
AUTO_CREATE_PERIODS_DEFAULT_LENGTH_DAYS=14
AUTO_CREATE_PERIODS_DEFAULT_GAP_DAYS=0

# Optional local diagnostics page (staff + localhost only)
LOCAL_STATUS_ENABLED=true
LOCAL_STATUS_ACCESS_LOG_FILE=.run/logs/access.log
LOCAL_STATUS_LOG_LINES=120

# Optional
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
