# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications → your app → Bot
DISCORD_BOT_TOKEN=

# Application (client) ID — General Information tab
DISCORD_CLIENT_ID=

# Set to your server (guild) ID for instant command registration during dev.
# Leave blank to register global commands (takes ~1 hour to propagate).
DISCORD_GUILD_ID=

# ── Web App API ───────────────────────────────────────────────────────────────
# Base URL for the Flask web app (no trailing slash)
WEB_APP_BASE_URL=http://127.0.0.1:5001

# Shared secret — must match WEB_APP_API_TOKEN in apps/web/.env
WEB_APP_API_TOKEN=
