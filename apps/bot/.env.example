BOT_TOKEN=
CLIENT_ID=
TEST_GUILD_ID=
TEST_REQUESTER_DISCORD_ID=
BOT_TESTER_IDS=

# Optional API bridge to the Flask web app
WEB_APP_BASE_URL=http://127.0.0.1:5001
WEB_APP_API_TOKEN=
REQUEST_TIMEOUT_MS=10000

# Optional claim-context cache/retry tuning
CLAIM_CONTEXT_CACHE_TTL_MS=30000
CLAIM_CONTEXT_STALE_IF_ERROR_MS=300000
CLAIM_CONTEXT_MAX_RETRIES=2
CLAIM_CONTEXT_RETRY_BASE_MS=250

# Optional review notifier (issue #23): posts claim/spend approvals/denials
# into channels/threads whose names match character names.
REVIEW_NOTIFIER_ENABLED=false
REVIEW_NOTIFIER_GUILD_ID=
REVIEW_NOTIFIER_INTERVAL_MS=60000
REVIEW_NOTIFIER_LOOKBACK_SECONDS=86400

# Optional auto-night creator (issue #22): bot triggers server-side
# next-night creation when due.
AUTO_PERIOD_CREATOR_ENABLED=false
AUTO_PERIOD_CREATOR_INTERVAL_MS=3600000

# Optional issue #20: sunrise claim reminders (DMs to players with active
# characters who have not filed for the current open night).
CLAIM_REMINDER_ENABLED=false
CLAIM_REMINDER_GUILD_ID=
CLAIM_REMINDER_INTERVAL_MS=900000
CLAIM_REMINDER_WEEKDAY_LOCAL=0
CLAIM_REMINDER_HOUR_LOCAL=12
CLAIM_REMINDER_MINUTE_LOCAL=0
CLAIM_REMINDER_TIMEZONE=America/New_York
CLAIM_REMINDER_SNOOZE_HOURS=24

# Optional passage-of-time scheduler (bot-only, no extra cloud services)
PASSAGE_OF_TIME_ENABLED=false
PASSAGE_OF_TIME_GUILD_ID=
PASSAGE_OF_TIME_CHANNEL_ID=
PASSAGE_OF_TIME_TEST_MODE=true
PASSAGE_OF_TIME_TEST_CHANNEL_ID=
PASSAGE_OF_TIME_INTERVAL_MS=900000
PASSAGE_OF_TIME_TIMEZONE=America/New_York
PASSAGE_OF_TIME_KINDRED_ROLE_ID=
PASSAGE_OF_TIME_GHOUL_ROLE_ID=
PASSAGE_OF_TIME_MORTAL_ROLE_ID=

# Cadence anchors must be YYYY-MM-DD dates in local timezone.
# Sunrise and sunset events run every 2 weeks; downtime runs every 8 weeks.
PASSAGE_SUNRISE_WEEKDAY_LOCAL=0
PASSAGE_SUNRISE_HOUR_LOCAL=12
PASSAGE_SUNRISE_MINUTE_LOCAL=0
PASSAGE_SUNRISE_ANCHOR_DATE=

PASSAGE_SUNSET_WEEKDAY_LOCAL=2
PASSAGE_SUNSET_HOUR_LOCAL=12
PASSAGE_SUNSET_MINUTE_LOCAL=0
PASSAGE_SUNSET_ANCHOR_DATE=

PASSAGE_DOWNTIME_WEEKDAY_LOCAL=0
PASSAGE_DOWNTIME_HOUR_LOCAL=12
PASSAGE_DOWNTIME_MINUTE_LOCAL=0
PASSAGE_DOWNTIME_ANCHOR_DATE=

# Optional player-facing quick guide URL (Discord post, docs page, etc.)
PLAYER_GUIDE_URL=

# Optional player-facing web URL used in /xp help
PLAYER_WEB_URL=

# Optional Docker log retention controls (used by apps/bot/docker-compose.yml)
BOT_LOG_MAX_SIZE=25m
BOT_LOG_MAX_FILE=120
TZ=America/New_York
